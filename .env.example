# Nephro OS — Environment Variables
# Copy to .env and fill in real values (never commit .env)

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Project: nephro-os | Region: eu-central-1
DATABASE_URL="postgresql://neondb_owner:<password>@ep-winter-cloud-alz3wv3q.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_POOLER="postgresql://neondb_owner:<password>@ep-winter-cloud-alz3wv3q-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Cloudflare R2 (Object Storage) ─────────────────────────────────────────
# Bucket: nephro-os
# Create token at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID="c22c14c1035351bf35821cd861653d70"
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="nephro-os"
CLOUDFLARE_R2_ENDPOINT="https://c22c14c1035351bf35821cd861653d70.r2.cloudflarestorage.com"

# ─── Fly.io (Future API/Backend) ─────────────────────────────────────────────
# App: nephro-os-api | Region: fra (Frankfurt)
# Set secrets via: fly secrets set KEY=VALUE -a nephro-os-api
FLY_APP_NAME="nephro-os-api"
FLY_REGION="fra"

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="Nephro OS"
VITE_API_URL="http://localhost:8080"
